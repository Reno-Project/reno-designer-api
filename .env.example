# --- Azure PostgreSQL (admin user, direct connection) ---
DATABASE_CLIENT=
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
# Schema inside the Azure DB that holds this app's tables.
DATABASE_SCHEMA=designers
# Azure requires TLS. Leave true unless you know what you're doing.
DATABASE_SSL=true

# --- Auth ---
# Dev bypass: when true, every request is treated as DEV_USER_ID.
# Leave false in any shared / deployed environment.
AUTH_DISABLED=false
DEV_USER_ID=00000000-0000-0000-0000-000000000001
# Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
# Required unless AUTH_DISABLED=true.
SUPABASE_JWT_SECRET=

# --- HTTP server ---
PORT=4000
# Comma-separated. Add deployed origins later.
CORS_ORIGINS=
